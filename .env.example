# PostgreSQL connection string.
# Local development uses Homebrew PostgreSQL 17 with trust auth (no password).
DATABASE_URL=postgresql://USER@localhost:5432/financial_tracker

# Dedicated destructive-test database. The reversal runner requires an _test suffix.
TEST_DATABASE_URL=postgresql://USER@localhost:5432/financial_tracker_test

# EODHD API credential; keep the value only in the untracked .env file.
EODHD_API_TOKEN=
