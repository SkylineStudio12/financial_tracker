#!/bin/sh
# Token-conformance gate on STAGED .ts/.tsx files (docs/review-standards.md §2.2).
#
# Deliberately grep-only: measured eslint cold-start here is ~10s, far over
# the ~2s hook budget (§5), so eslint and tsc stay at review time. This hook
# enforces OBJECTIVE criteria only — never the judgment layer.
#
# Intentional bypass: git commit --no-verify

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$')
[ -z "$STAGED" ] && exit 0

fail=0
check() {
  hits=$(echo "$STAGED" | xargs grep -nE "$2" 2>/dev/null)
  if [ -n "$hits" ]; then
    printf '\n✗ %s\n%s\n' "$1" "$hits"
    fail=1
  fi
}

check "G1 color literal (hex/rgb()/oklch()/[#…]) — semantic tokens only" \
  '#[0-9a-fA-F]{6}\b|rgb\(|oklch\(|-\[#'
check "G2 dark: variant — light-first system, no dark classes" \
  'dark:'
check "G3 heavy font weight — Medium (500) is the ceiling" \
  'font-(semibold|bold|extrabold|black)'
check "G4 raw Tailwind palette / Tier-1 primitive color in components" \
  '(bg|text|border|ring|fill|stroke)-(red|blue|green|slate|gray|zinc|neutral|stone|amber|yellow|lime|emerald|teal|cyan|sky|indigo|violet|purple|fuchsia|pink|rose|orange)-[0-9]{2,3}'

if [ $fail -eq 1 ]; then
  printf '\nToken gate failed (docs/review-standards.md §2.2). Fix, or bypass deliberately with --no-verify.\n'
fi
exit $fail
